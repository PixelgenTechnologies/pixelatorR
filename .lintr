linters: linters_with_defaults(
    line_length_linter(120L),
    object_name_linter = NULL,
    quotes_linter = NULL,
    function_left_parentheses_linter = NULL,
    object_length_linter(45L),
    cyclocomp_linter = NULL,
    object_usage_linter = NULL
  )
exclusions: list(
    "vignettes/",
    "tests/"
  )
